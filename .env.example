# .env.example — MCP Nexus RAG
# Copy to .env and set values appropriate for your environment.
# All variables are optional — sensible defaults are used if not set.

# ── Service Endpoints ────────────────────────────────────────────────────────
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-strong-password>       # REQUIRED in production — default is insecure

QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379
OLLAMA_URL=http://localhost:11434

# ── Models ───────────────────────────────────────────────────────────────────
EMBED_MODEL=nomic-embed-text                # Ollama embedding model
LLM_MODEL=qwen2.5:3b                      # Ollama LLM for answer_query synthesis
RERANKER_MODEL=BAAI/bge-reranker-v2-m3     # HuggingFace cross-encoder reranker

# ── Model Tuning ─────────────────────────────────────────────────────────────
LLM_TIMEOUT=300.0                          # Seconds before LLM call times out
CONTEXT_WINDOW=32768                       # Model context window (tokens)
CHUNK_SIZE=1024                            # Chunk size for LLM index (tokens)
CHUNK_OVERLAP=128                          # Chunk overlap (tokens)
INGEST_CHUNK_SIZE=1024                     # Override chunk size at ingest time
INGEST_CHUNK_OVERLAP=128                   # Override chunk overlap at ingest time

# ── Retrieval ────────────────────────────────────────────────────────────────
RERANKER_ENABLED=true                      # Enable/disable cross-encoder reranker
RERANKER_TOP_N=5                           # Return top-N results after reranking
RERANKER_CANDIDATE_K=20                    # Fetch K candidates before reranking
MAX_CONTEXT_CHARS=1500                     # Max characters returned by retrieval tools
MAX_DOCUMENT_SIZE=4096                     # Max document bytes before auto-chunking

# ── Cache ────────────────────────────────────────────────────────────────────
CACHE_ENABLED=true                         # Enable Redis semantic cache (24h TTL)

# ── Watcher / Sync ───────────────────────────────────────────────────────────
WORKSPACE_ROOT=/home/turiya/antigravity    # Root path watched for core doc changes
RAG_SYNC_DEBOUNCE=3.0                      # Seconds to debounce rapid file saves

# ── Environment ──────────────────────────────────────────────────────────────
NEXUS_ENV=development                      # Set to "production" for strict validation
